{
  "name": "chat2ide",
  "version": "1.0.0",
  "private": true,
  "description": "Remote Codex CLI Terminal Hub",
  "engines": {
    "node": ">=16.20.0"
  },
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "dev": "concurrently -k \"tsx watch src/server/index.ts\" \"vite\"",
    "build": "tsc -p tsconfig.server.json && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p web/tsconfig.json",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "cookie": "^0.6.0",
    "express": "^4.21.2",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.3",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^18.19.72",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^3.14.0",
    "typescript": "^5.8.3",
    "vite": "^4.5.5"
  }
}
